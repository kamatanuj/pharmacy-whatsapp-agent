# Meta WhatsApp Cloud API
META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN
META_PHONE_NUMBER_ID=YOUR_META_PHONE_NUMBER_ID
META_VERIFY_TOKEN=YOUR_WEBHOOK_VERIFY_TOKEN

# LLM Config — choose local OR cloud
# Local (free, dev): ornith:9b on local Ollama
LLM_MODEL=ornith:9b
LLM_API_URL=http://localhost:11434/v1/chat/completions

# Cloud (production): GLM-5.2 or Gemini via Ollama Cloud
# LLM_MODEL=glm-5.2:cloud
# LLM_API_URL=https://ollama.com/v1/chat/completions
# OLLAMA_CLOUD_API_KEY=YOUR_OLLAMA_CLOUD_API_KEY
# OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1

# Pharmacy DB (mock for now — replace with real API later)
PHARMACY_DB_URL=http://localhost:8001
DB_API_KEY=YOUR_DB_API_KEY

# Server
HOST=0.0.0.0
PORT=8000
